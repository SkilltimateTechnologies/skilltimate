# ============================================================================
#  Skilltimate — environment variables
#  Copy to `.env` for local dev, or paste into Railway → Variables (Raw Editor)
#  for production. Values below are placeholders — fill in the real ones.
# ============================================================================

# --- Required (server will refuse to start without these) -------------------

# "production" on Railway, "development" locally.
NODE_ENV=production

# Public URL the site is served from. NO trailing slash.
# Local dev:  http://localhost:3000
# Railway:    https://<your-service>.up.railway.app
WEBSITE_URL=https://skilltimate-production.up.railway.app

# Turso database URL (libsql://...)
DATABASE_URL=libsql://your-db.turso.io

# Turso auth token (long JWT). Generate: `turso db tokens create <db>`
DATABASE_AUTH_TOKEN=

# Better Auth signing secret. Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# --- Admin login (used once to create the single admin account) -------------
# The server auto-creates this admin on first boot (idempotent).
ADMIN_EMAIL=skilltimate.studio@gmail.com
ADMIN_PASSWORD=change-me-strong-password

# --- Provided automatically by Railway — do NOT set manually ----------------
# PORT   ← Railway injects this (usually 8080). server.ts reads process.env.PORT.
